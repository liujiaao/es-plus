{
  "name": "@es-plus/mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for es-plus-ui - AI coding tool integration for CRUD page generation",
  "type": "module",
  "bin": {
    "mcp-server-es-plus": "./build/index.js"
  },
  "main": "./build/index.js",
