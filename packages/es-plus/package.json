{
  "name": "es-plus-ui",
  "version": "1.0.1",
  "description": "基于 Vue 3 和 Element Plus 的企业级中后台前端组件库",
  "type": "module",
  "main": "./dist/es-plus.umd.cjs",
  "module": "./dist/es-plus.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/es-plus.js",
      "require": "./dist/es-plus.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "echo 'Skipping build, already built'",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "vue3",
    "vue",
    "element-plus",
    "component-library",
    "form",
    "table",
    "dialog",
    "es-plus",
    "typescript",
    "enterprise",
    "config-driven",
    "crud"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "vue": "^3.2.0",
    "element-plus": "^2.2.0",
    "@element-plus/icons-vue": "^2.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^14.0.0",
    "sass": "^1.70.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0",
    "vue": "^3.4.0",
    "vue-tsc": "^1.8.0",
    "element-plus": "^2.5.0"
  }
}
