{
  "name": "@es-plus/vue2",
  "version": "1.1.2",
  "description": "es-plus for Vue 2 + Element UI: configuration-driven enterprise components, sharing the same JSON config schema as @es-plus/vue3 (Vue 3 + Element Plus)",
  "main": "./dist/es-plus-vue2.umd.cjs",
  "module": "./dist/es-plus-vue2.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/es-plus-vue2.js",
      "require": "./dist/es-plus-vue2.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "build": "vite build",
    "prepublishOnly": "npm run typecheck && npm run build",
    "pretest": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "vue2",
    "vue",
    "element-ui",
    "component-library",
    "form",
    "table",
    "dialog",
    "es-plus",
    "typescript",
    "enterprise",
    "config-driven",
    "crud",
    "json-schema"
  ],
  "author": "liujiaao <303363554@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liujiaao/es-plus.git",
    "directory": "packages/vue2"
  },
  "homepage": "https://liujiaao.github.io/es-plus/",
  "bugs": {
    "url": "https://github.com/liujiaao/es-plus/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@vue/composition-api": "^1.7.0",
    "element-ui": "^2.15.0",
    "vue": "^2.6.14 || ^2.7.0"
  },
  "dependencies": {
    "@es-plus/core": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vue/composition-api": "^1.7.2",
    "@vitejs/plugin-vue2": "^2.3.0",
    "element-ui": "^2.15.14",
    "sass": "^1.70.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0",
    "vue": "^2.7.16",
    "vue-template-compiler": "^2.7.16"
  }
}
