<script setup lang="jsx">
import { reactive, ref, h } from 'vue'
import { useDialog } from '@es-plus/vue3'
import { ElTag } from 'element-plus'

const queryForm = reactive({ name: '', department: '', position: '' })
const tableData = ref([])
const tableRef = ref(null)
const pagination = ref({ current: 1, pageSize: 10, total: 0 })
const dialog = useDialog()

const formItems = [
  {
    "prop": "name",
    "label": "姓名",
    "formtype": "Input",
    "span": 6,
    "attrs": {
      "clearable": true,
      "placeholder": "请输入姓名"
    }
  },
  {
    "prop": "department",
    "label": "部门",
    "formtype": "Input",
    "span": 6,
    "attrs": {
      "clearable": true,
      "placeholder": "请输入部门"
    }
  },
  {
    "prop": "position",
    "label": "职位",
    "formtype": "Input",
    "span": 12,
    "attrs": {
      "clearable": true,
      "placeholder": "请输入职位"
    }
  }
]

const queryBtns = [
  { name: '查询', type: 'primary', key: 'query', triggerEvent: true },
  { name: '重置', key: 'rest', triggerEvent: true },
  { name: '新增', type: 'primary', key: 'add', icon: 'Plus', click: () => openForm('新增') },
]

const columns = [
  {
    "prop": "name",
    "label": "姓名"
  },
  {
    "prop": "department",
    "label": "部门"
  },
  {
    "prop": "position",
    "label": "职位"
  },
  {
    "prop": "gender",
    "label": "性别"
  },
  {
    "prop": "age",
    "label": "年龄"
  },
  {
    "prop": "phone",
    "label": "手机号"
  },
  {
    "prop": "status",
    "label": "状态",
    render: (_, { row }) => h(ElTag, { type: row.status === 1 ? 'success' : 'danger' }, () => row.status === 1 ? '启用' : '禁用')
  },
  {
    "prop": "operate",
    "label": "操作",
    "width": 100,
    "btns": [
      {
        "name": "编辑", "type": "primary", "clickEvent": (row) => openForm('编辑', row)
      }
    ]
  }
]

const options = {
  "border": true,
  "stripe": true,
  "highlightCurrentRow": true,
  "headerCellStyle": {
    "background": "#f5f7fa"
  },
  "rowkey": "id"
}

function openForm(title, row = {}) {
  const formData = reactive({ name: '', department: '', position: '', gender: '', age: '', phone: '', status: '', ...row })
  const isView = title === '查看'
  dialog({
    title,
    width: '500px',
    render: (h, { registerRef }) => (
      <EsForm
        ref={el => el && registerRef('form', el)}
        model={formData}
        formItemList={[
        {
                "prop": "name",
                "label": "姓名",
                "formtype": "Input",
                "span": 24,
                "attrs": {
                        "clearable": true,
                        "placeholder": "请输入姓名"
                },
                "formItemOptions": {
                        "rules": [
                                {
                                        "required": true,
                                        "message": "请输入姓名",
                                        "trigger": "blur"
                                }
                        ]
                }
        },
        {
                "prop": "department",
                "label": "部门",
                "formtype": "Input",
                "span": 24,
                "attrs": {
                        "clearable": true,
                        "placeholder": "请输入部门"
                },
                "formItemOptions": {
                        "rules": [
                                {
                                        "required": true,
                                        "message": "请输入部门",
                                        "trigger": "blur"
                                }
                        ]
                }
        },
        {
                "prop": "position",
                "label": "职位",
                "formtype": "Input",
                "span": 24,
                "attrs": {
                        "clearable": true,
                        "placeholder": "请输入职位"
                },
                "formItemOptions": {
                        "rules": [
                                {
                                        "required": true,
                                        "message": "请输入职位",
                                        "trigger": "blur"
                                }
                        ]
                }
        },
        {
                "prop": "gender",
                "label": "性别",
                "formtype": "Radio",
                "span": 24,
                "attrs": {
                        "clearable": true,
                        "placeholder": "请选择性别"
                },
                "formItemOptions": {
                        "rules": [
                                {
                                        "required": true,
                                        "message": "请选择性别",
                                        "trigger": "change"
                                }
                        ]
                },
                "dataOptions": [
                        {
                                "label": "男",
                                "value": "male"
                        },
                        {
                                "label": "女",
                                "value": "female"
                        }
                ]
        },
        {
                "prop": "age",
                "label": "年龄",
                "formtype": "Input",
                "span": 24,
                "attrs": {
                        "clearable": true,
                        "placeholder": "请输入年龄"
                },
                "formItemOptions": {
                        "rules": [
                                {
                                        "required": true,
                                        "message": "请输入年龄",
                                        "trigger": "blur"
                                }
                        ]
                }
        },
        {
                "prop": "phone",
                "label": "手机号",
                "formtype": "Input",
                "span": 24,
                "attrs": {
                        "clearable": true,
                        "placeholder": "请输入手机号"
                },
                "formItemOptions": {
                        "rules": [
                                {
                                        "required": true,
                                        "message": "请输入手机号",
                                        "trigger": "blur"
                                }
                        ]
                }
        },
        {
                "prop": "status",
                "label": "状态",
                "formtype": "Select",
                "span": 24,
                "attrs": {
                        "clearable": true,
                        "placeholder": "请选择状态"
                },
                "formItemOptions": {
                        "rules": [
                                {
                                        "required": true,
                                        "message": "请选择状态",
                                        "trigger": "change"
                                }
                        ]
                },
                "dataOptions": [
                        {
                                "label": "启用",
                                "value": 1
                        },
                        {
                                "label": "禁用",
                                "value": 0
                        }
                ]
        }
]}
      />
    ),
    configBtn: isView ? [
      { name: '关闭', click: (_, { close }) => close() }
    ] : [
      { name: '取消', click: (_, { close }) => close() },
      { name: '确定', type: 'primary', click: async (_, { close, getRefs }) => {
        try {
          await getRefs('form')?.validate()
          // TODO: 调用保存接口
          // await axios.post('/api/save', formData)
          close()
          tableRef.value?.httpRequestInstance()
        } catch {
          // 表单验证失败
        }
      }}
    ]
  })
}
</script>"
`;

