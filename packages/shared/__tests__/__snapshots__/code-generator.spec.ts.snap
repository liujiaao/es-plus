]}
      />
    ),
    configBtn: isView ? [
      { name: '关闭', click: (_, { close }) => close() }
    ] : [
      { name: '取消', click: (_, { close }) => close() },
      { name: '确定', type: 'primary', click: async (_, { close, getRefs }) => {
        try {
          await getRefs('form')?.validate()
          // TODO: 调用保存接口
