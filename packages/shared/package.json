{
  "name": "@es-plus/shared",
  "version": "1.1.1",
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    },
    "./contract": {
      "types": "./build/contract.d.ts",
      "import": "./build/contract.js"
    }
  },
  "files": [
    "build",
    "schemas"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update": "vitest run --update"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
