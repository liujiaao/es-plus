{
  "name": "@es-plus/cli",
  "version": "1.2.1",
  "description": "CLI tool for es-plus (Vue 3 / Vue 2) - generate CRUD pages, validate configs",
  "type": "module",
  "bin": {
    "es-plus": "./build/index.js"
  },
  "main": "./build/index.js",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "es-plus",
    "cli",
    "crud",
    "vue3",
    "code-generator",
    "element-plus"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/liujiaao/es-plus.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@es-plus/shared": "^1.0.0",
    "commander": "^12.0.0",
    "prompts": "^2.4.2",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.0",
    "typescript": "^5.3.0"
  }
}
