{
  "name": "@es-plus/vue3",
  "version": "1.4.2",
  "description": "es-plus for Vue 3 + Element Plus: configuration-driven enterprise components, sharing the same JSON config schema as @es-plus/vue2 (Vue 2 + Element UI). Renamed from es-plus-ui starting v1.4.0.",
  "type": "module",
  "main": "./dist/es-plus.umd.cjs",
  "module": "./dist/es-plus.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/es-plus.js",
      "require": "./dist/es-plus.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./resolver": {
      "import": "./dist/resolver.mjs",
      "require": "./dist/resolver.cjs",
      "types": "./dist/resolver.d.ts"
    },
    "./dist/style.css": "./dist/style.css",
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "typecheck": "vue-tsc --noEmit -p tsconfig.build.json",
    "typecheck:all": "vue-tsc --noEmit",
    "build": "vite build",
    "prepublishOnly": "npm run typecheck && npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "vue3",
    "vue",
    "element-plus",
    "component-library",
    "form",
    "table",
    "dialog",
    "es-plus",
    "typescript",
    "enterprise",
    "config-driven",
    "crud",
    "json-schema",
    "ai-friendly"
  ],
  "author": "liujiaao <303363554@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liujiaao/es-plus.git",
    "directory": "packages/vue3"
  },
  "homepage": "https://liujiaao.github.io/es-plus/",
  "bugs": {
    "url": "https://github.com/liujiaao/es-plus/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "element-plus": "^2.2.0",
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "@vue/test-utils": "^2.4.0",
    "element-plus": "^2.5.0",
    "happy-dom": "^14.0.0",
    "sass": "^1.70.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0",
    "vue": "^3.4.0",
    "vue-tsc": "^3.3.1"
  }
}
